generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ÉNUMÉRATIONS ====================

enum Role {
  USER
  CONTRIBUTOR
  EDITOR
  EXPERT        // Membre du comité scientifique de validation (ILA-UFHB)
  ADMIN
  SUPER_ADMIN
}

// Statut de certification des contributions audio par le comité
enum CertificationStatus {
  SUBMITTED          // Soumis par le locuteur, en attente de review
  IN_REVIEW          // En cours d'examen par le comité
  CERTIFIED_ILA      // Certifié (quorum 3/5 atteint) — données de référence
  REVISION_REQUESTED // Révision demandée par le comité
  REJECTED           // Rejeté par le comité
}

// Type de vote d'un expert sur une contribution
enum ExpertVoteType {
  APPROVED           // Approuvé
  REVISION_REQUESTED // Révision demandée
  REJECTED           // Rejeté
}

enum ContentStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum ContributionType {
  WORD
  PHRASE
  IMAGE
}

enum ExerciseType {
  LISTENING
  VOCABULARY
  GRAMMAR
  GAME
  TRANSLATION
  IMAGE_WORD
}

enum LessonStepType {
  VOCABULARY
  DIALOGUE
  GRAMMAR
  EXERCISE
}

enum CulturalItemType {
  PROVERB
  TRADITION
  ANECDOTE
  TALE
  MUSIC
  DANCE
  TRESOR
}

enum NotificationType {
  SYSTEM
  BADGE
  STREAK
  LESSON
  PROMO
  DAILY_REMINDER
  BADGE_EARNED
  CHALLENGE
  CULTURAL_POINT
  STREAK_WARNING
  PHONE_VALIDATED
  // Cursus scolaire (Phase D)
  BULLETIN_VALIDE
  PASSAGE_CLASSE
  EXAMEN_REFUSE
}

// ==================== UTILISATEURS ====================

model User {
  id                  String    @id @default(uuid())
  nom                 String
  prenom              String
  email               String?   @unique   // Optionnel si inscription par téléphone
  identifiant         String?   @unique
  motDePasseHash      String?
  dateNaissance       DateTime?
  telephone           String?   @unique   // Identifiant unique si connexion par tél.
  phoneVerified       Boolean   @default(false)
  genre               String?   // 'M' | 'F' | 'AUTRE'
  photo               String?
  role                Role      @default(USER)
  isPremium           Boolean   @default(false)
  premiumUntil        DateTime?
  pointsContribution  Int       @default(0)
  bonusXp             Int       @default(0)   // XP hors-leçons (jeux, S.O.S., marché…)
  streak              Int       @default(0)
  lastActiveAt        DateTime?
  isActive            Boolean   @default(true)

  // OAuth
  googleId            String?   @unique
  facebookId          String?   @unique

  // Préférences
  niveauPref          String?
  languesFavorites    String[]
  notifEnabled        Boolean   @default(true)
  tuteurPref          String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  progress            UserProgress[]
  contributions       Contribution[]
  imageContributions  ImageContribution[]
  badges              UserBadge[]
  pronunciationReqs   PronunciationRequest[]
  notifications       Notification[]
  organizationMember  OrganizationMember[]
  audioContributions  AudioContribution[]
  practiceSessions    PracticeSession[]
  supportMessages       SupportMessage[]
  certificates          Certificate[]
  financeContributions  FinanceContribution[]
  depensesCreees        Depense[]             @relation("depensesCreees")
  expertVotes           ValidationVote[]      // votes du comité scientifique (rôle EXPERT)
  enrollments           Enrollment[]          // cursus scolaire par langue
  placementResults      PlacementResult[]     // tests de positionnement
  examSubmissions       ExamSubmission[]      @relation("examSubmissions")
  examReviews           ExamSubmission[]      @relation("examReviews")
  bulletinValidations   Bulletin[]            @relation("bulletinValidations")
  fichesCrees           FichePedagogique[]    @relation("FicheCreator")

  @@map("users")
}

// ==================== OTP TÉLÉPHONE ====================

model PhoneOTP {
  id          String   @id @default(uuid())
  telephone   String                     // numéro E.164 (ex: +2250708XXXXXX)
  code        String                     // 6 chiffres
  expiresAt   DateTime                   // valide 10 minutes
  used        Boolean  @default(false)
  attempts    Int      @default(0)       // max 3 tentatives
  createdAt   DateTime @default(now())

  @@index([telephone])
  @@map("phone_otps")
}

// ==================== LANGUES ====================

model Language {
  id              String    @id @default(uuid())
  nom             String    @unique
  code            String    @unique  // ex: "baoule", "dioula"
  famille         String?   // Akan, Mandé, Krou, etc.
  region          String?
  locuteurs       Int?
  imageDrapeau    String?
  description     String?
  ordreAffichage       Int       @default(0)
  isActive             Boolean   @default(true)
  isInMvp              Boolean   @default(false)

  // Onboarding — son & message de bienvenue
  traditionalAudioUrl  String?   // URL Cloudinary du son traditionnel (~5s)
  welcomeMessage       String?   // Message lu en TTS à la sélection de langue

  // Multi-pays (Phase 5)
  countryCode     String?   @default("CI")   // ISO 3166-1 alpha-2 (ex: "CI", "ML", "BF", "SN")
  countryName     String?   @default("Côte d'Ivoire")  // Nom complet du pays

  // Carte géographique
  lat             Float?    // Latitude (ex: 7.54)
  lng             Float?    // Longitude (ex: -5.55)
  couleur         String?   // Couleur hexadécimale (ex: "#D4A017")
  emoji           String?   // Emoji représentatif (ex: "🌿")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  lessons         Lesson[]
  dictEntries     DictionaryEntry[]
  usefulPhrases   UsefulPhrase[]
  contributions   Contribution[]
  culturalItems   CulturalItem[]
  tutors          Tutor[]
  videos          Video[]
  audioContribs   AudioContribution[]
  practiceSessions PracticeSession[]
  certificates    Certificate[]
  premierSecoursPhrases PremierSecoursPhrase[]
  civicContents   CivicContent[]
  textContents    TextContent[]
  imageGalleries  ImageGallery[]
  marcheDialogues MarcheDialogue[]
  sensMots        SensMot[]
  mathContenus    MathContenu[]
  monnaieContenus MonnaieContenu[]
  enrollments     Enrollment[]
  placementQuestions PlacementQuestion[]
  placementResults   PlacementResult[]
  examSubmissions    ExamSubmission[]
  fichesPedagogiques FichePedagogique[]

  @@map("languages")
}

// ==================== LEÇONS ====================

model Lesson {
  id          String    @id @default(uuid())
  languageId  String
  titre       String
  description String?
  ordre       Int       @default(0)
  pointsXp    Int       @default(50)
  niveau      String    @default("A1") // A1, A2, B1, B2, C1 (hérité — remplacé progressivement par gradeLevelId)
  imageUrl    String?
  isActive    Boolean   @default(true)

  // Cursus scolaire (Phase A)
  gradeLevelId  String?        // Classe à laquelle la leçon appartient (null = hors cursus)
  pilier        PilierMatiere? // Matière (pilier du Socle Commun)
  isObligatoire Boolean        @default(true)  // Requise pour le passage de classe

  // Progression trimestrielle (Phase C1 — alignement DPFC)
  trimestre     Trimestre?     // T1 / T2 / T3 — période dans l'année scolaire
  semaine       Int?           // Semaine dans le trimestre (1-12)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  language    Language  @relation(fields: [languageId], references: [id])
  gradeLevel  GradeLevel? @relation(fields: [gradeLevelId], references: [id])
  steps       LessonStep[]
  progress    UserProgress[]
  notes       NoteLecon[]

  @@index([gradeLevelId])
  @@map("lessons")
}

model LessonStep {
  id        String         @id @default(uuid())
  lessonId  String
  type      LessonStepType
  contenu   Json           // contenu dynamique selon le type
  ordre     Int            @default(0)
  audioUrl  String?
  imageUrl  String?

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@map("lesson_steps")
}

model Exercise {
  id          String       @id @default(uuid())
  stepId      String
  type        ExerciseType
  donnees     Json         // questions, choix, etc.
  solution    Json         // réponses correctes
  pointsXp    Int          @default(10)
  explication String?

  step        LessonStep   @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("exercises")
}

// ==================== DICTIONNAIRE ====================

model DictionaryEntry {
  id              String        @id @default(uuid())
  languageId      String
  mot             String
  transcription   String?       // notation phonétique
  traduction      String        // traduction en français
  audioUrl        String?
  imageUrl        String?
  exemplePhrase   String?
  exempleTraduction String?
  categorie       String?       // corps, nature, famille, etc.
  statutSRS       Int           @default(0)  // niveau mémorisation 0-5
  status          ContentStatus @default(DRAFT)
  contributorId   String?
  moderatorId     String?
  moderatedAt     DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  language        Language      @relation(fields: [languageId], references: [id])
  pronunciationReqs PronunciationRequest[]

  @@index([languageId, status])
  @@map("dictionary_entries")
}

model UsefulPhrase {
  id            String        @id @default(uuid())
  languageId    String
  phrase        String
  transcription String?
  traduction    String
  audioUrl      String?   // langue locale
  audioUrlFr    String?   // français
  audioUrlF     String?   // langue locale — locutrice (femme)
  audioUrlFrF   String?   // français — locutrice (femme)
  categorie     String?   // salutations, commerce, urgence, etc.
  contexte      String?
  genreLocuteur String?   // 'M' | 'F' | null — genre du locuteur audio
  status        ContentStatus @default(DRAFT)
  contributorId String?
  moderatorId   String?
  moderatedAt   DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  language      Language      @relation(fields: [languageId], references: [id])

  @@index([languageId, status])
  @@map("useful_phrases")
}

// ==================== CONTRIBUTIONS ====================

model Contribution {
  id            String           @id @default(uuid())
  userId        String
  type          ContributionType
  languageId    String
  contenu       Json             // mot/phrase + traduction + contexte
  audioUrl      String?
  imageUrl      String?
  status        ContentStatus    @default(PENDING)
  moderatorId   String?
  moderatedAt   DateTime?
  commentaire   String?          // retour du modérateur

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id])
  language      Language         @relation(fields: [languageId], references: [id])

  @@index([status, type])
  @@map("contributions")
}

model ImageContribution {
  id            String        @id @default(uuid())
  userId        String
  languageId    String
  imageUrl      String
  legende       String?
  motAssocie    String?
  categorie     String?
  source        String?
  status        ContentStatus @default(PENDING)
  moderatorId   String?
  moderatedAt   DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])

  @@map("image_contributions")
}

// ==================== CONTENU CULTUREL ====================

model CulturalItem {
  id              String           @id @default(uuid())
  languageId      String?
  type            CulturalItemType
  titre           String?
  contenu         String
  traduction      String?
  audioUrl        String?
  imageUrl        String?
  videoUrl        String?
  auteur          String?
  sourceEthnique  String?          // ethnie pour les TRESOR (baoule, dioula, etc.)
  seuilXp         Int?             // XP nécessaire pour débloquer (TRESOR)
  matiere         String?          // matière de fabrication (TRESOR)
  typeObjet       String?          // type d'objet (TRESOR)
  emoji           String?          // emoji représentatif (TRESOR)
  audioUrlFr      String?          // audio en français
  audioUrlF       String?          // langue locale — locutrice (femme)
  audioUrlFrF     String?          // français — locutrice (femme)
  datePublication DateTime         @default(now())
  isActive        Boolean          @default(true)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  language        Language?        @relation(fields: [languageId], references: [id])

  @@map("cultural_items")
}

// ==================== TUTEURS IA ====================

model Tutor {
  id                  String   @id @default(uuid())
  languageId          String
  nomAvatar           String
  genre               String   @default("M") // M ou F
  imageUrl            String?
  videoUrl            String?
  voixConfig          Json     // config TTS, vitesse, pitch, etc.
  personalite         String?
  messagesPersonnalises Json?
  isActive            Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  language            Language @relation(fields: [languageId], references: [id])

  @@map("tutors")
}

model PronunciationRequest {
  id              String   @id @default(uuid())
  userId          String
  dictEntryId     String
  audioRecording  String   // URL du fichier audio
  feedbackAvatar  Json?    // scores par dimension
  scoreTones      Float?
  scoreConsonants Float?
  scoreVowels     Float?
  scoreRythm      Float?
  scoreGlobal     Float?

  createdAt       DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id])
  dictEntry       DictionaryEntry @relation(fields: [dictEntryId], references: [id])

  @@map("pronunciation_requests")
}

// ==================== PROGRESSION ====================

model UserProgress {
  id             String   @id @default(uuid())
  userId         String
  lessonId       String
  statut         String   @default("not_started") // not_started, in_progress, completed
  score          Int?
  xpGained       Int?
  dateCompletion DateTime?
  attempts       Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  lesson         Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("user_progress")
}

// ==================== GAMIFICATION ====================

model Badge {
  id          String   @id @default(uuid())
  nom         String   @unique
  description String
  imageUrl    String?
  categorie   String   // linguistique, culturel, social
  condition   Json     // règle d'obtention
  pointsXp    Int      @default(0)

  users       UserBadge[]

  @@map("badges")
}

model UserBadge {
  id          String   @id @default(uuid())
  userId      String
  badgeId     String
  obtainedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  badge       Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ==================== ORGANISATIONS ====================

model Organization {
  id        String   @id @default(uuid())
  nom       String
  email     String   @unique
  contact   String?
  statut    String   @default("active")
  apiKey    String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   OrganizationMember[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  userId         String
  organizationId String

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// ==================== VIDÉOS ====================

model Video {
  id            String        @id @default(uuid())
  languageId    String?
  titre         String
  description   String?
  url           String        // URL YouTube ou Cloudinary
  thumbnailUrl  String?
  duree         Int?          // durée en secondes
  categorie     String        @default("culturel") // prononciation, culturel, tutoriel, musique, documentaire
  source        String        @default("youtube") // youtube, cloudinary, externe
  ordre         Int           @default(0)
  isActive      Boolean       @default(true)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  language      Language?     @relation(fields: [languageId], references: [id])

  @@index([languageId, categorie])
  @@map("videos")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  titre     String
  corps     String
  isRead    Boolean          @default(false)
  data      Json?

  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ==================== CONTRIBUTIONS AUDIO (IA LINGUISTIQUE) ====================

model AudioContribution {
  id            String    @id @default(uuid())
  userId        String
  languageId    String
  mot           String                      // mot ou phrase en langue locale
  traduction    String?                     // traduction française
  audioUrl      String                      // URL de l'enregistrement audio
  transcription String?                     // notation phonétique
  categorie     String?                     // salutations, famille, marché...
  duree         Int?                        // durée en millisecondes
  isValidated   Boolean   @default(false)   // validé (rétrocompat — true quand CERTIFIED_ILA)
  validatedBy   String?
  validatedAt   DateTime?
  qualityScore  Float?                      // score qualité 0-5
  timesPlayed   Int       @default(0)       // nombre de fois joué par l'IA
  isActive      Boolean   @default(true)

  // Voix officielles par langue — homme/femme engagé professionnellement
  estVoixOfficielle Boolean @default(false)  // enregistrement d'un locuteur officiel
  genreVoix         String?                  // "F" (féminin) ou "M" (masculin)

  // Certification ILA — workflow comité 5 experts (quorum 3/5)
  certificationStatus CertificationStatus @default(SUBMITTED)
  certifiedAt         DateTime?            // date de certification ILA
  certifiedBy         String?              // ID du dernier expert ayant complété le quorum

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  language      Language  @relation(fields: [languageId], references: [id])
  validationVotes ValidationVote[]

  @@index([languageId, isValidated])
  @@index([mot, languageId])
  @@index([certificationStatus])
  @@map("audio_contributions")
}

// Vote d'un membre du comité scientifique sur une contribution audio
model ValidationVote {
  id                   String        @id @default(uuid())
  audioContributionId  String
  expertId             String        // User avec rôle EXPERT
  vote                 ExpertVoteType
  comment              String?       // Commentaire obligatoire si REVISION ou REJECTED
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  audioContribution  AudioContribution @relation(fields: [audioContributionId], references: [id], onDelete: Cascade)
  expert             User              @relation(fields: [expertId], references: [id])

  @@unique([audioContributionId, expertId])  // 1 vote par expert par contribution
  @@index([audioContributionId])
  @@index([expertId])
  @@map("validation_votes")
}

// ==================== SESSIONS DE PRATIQUE ====================

model PracticeSession {
  id            String    @id @default(uuid())
  userId        String
  languageId    String
  tutorId       String?
  mode          String    @default("listen_repeat") // listen_repeat, free_speak, quiz
  wordsCount    Int       @default(0)               // nombre de mots pratiqués
  correctCount  Int       @default(0)               // nombre de bonnes réponses
  duration      Int?                                // durée en secondes
  audioRecordings Json?                             // tableau d'URLs des enregistrements

  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  language      Language  @relation(fields: [languageId], references: [id])

  @@map("practice_sessions")
}

// ==================== MESSAGERIE SUPPORT ====================

model SupportMessage {
  id        String         @id @default(uuid())
  userId    String
  sujet     String
  corps     String
  statut    String         @default("OUVERT")  // OUVERT, EN_COURS, RESOLU
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user      User           @relation(fields: [userId], references: [id])
  reponses  SupportReply[]

  @@map("support_messages")
}

model SupportReply {
  id        String         @id @default(uuid())
  messageId String
  adminId   String?        // null si réponse utilisateur
  userId    String?        // null si réponse admin
  auteur    String         @default("ADMIN")  // 'ADMIN' | 'USER'
  corps     String
  createdAt DateTime       @default(now())

  message   SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("support_replies")
}

// ==================== CERTIFICATS ====================

model Certificate {
  id         String   @id @default(uuid())
  userId     String
  languageId String
  niveau     String   // A1, A2, B1, B2, C1
  issuedAt   DateTime @default(now())
  issuedBy   String?  // adminId qui a émis le certificat

  user       User     @relation(fields: [userId], references: [id])
  language   Language @relation(fields: [languageId], references: [id])

  @@unique([userId, languageId, niveau])
  @@map("certificates")
}

// ==================== PREMIERS SECOURS ====================

model PremierSecoursPhrase {
  id            String    @id @default(uuid())
  languageId    String?
  situation     String    // 'etouffement', 'arret_cardiaque', 'fracture', 'brulure', 'mise_en_securite', 'appel_secours', 'noyade', 'saignement', 'malaise', 'evaluation', 'guide_medical'
  consigne      String    // La consigne/phrase en langue locale
  traduction    String?   // Traduction française
  transcription String?   // Notation phonétique
  audioUrl      String?   // Audio prioritaire (bouton large) — langue locale
  audioUrlFr    String?   // Audio en français
  audioUrlF     String?   // langue locale — locutrice (femme)
  audioUrlFrF   String?   // français — locutrice (femme)
  imageUrl      String?   // Schéma illustré universel
  genreVoix     String?   // "M" ou "F"
  priorite      Int       @default(0) // 0=information, 1=important, 2=vital
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  language      Language? @relation(fields: [languageId], references: [id])

  @@map("premiers_secours_phrases")
}

// ==================== GALERIES D'IMAGES ====================

model ImageGallery {
  id          String        @id @default(uuid())
  languageId  String?
  rubrique    String        @default("")
  titre       String
  description String?
  coverUrl    String?
  ordre       Int           @default(0)
  status      ContentStatus @default(DRAFT)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  language    Language?     @relation(fields: [languageId], references: [id])
  images      GalleryImage[]

  @@index([languageId])
  @@map("image_galleries")
}

model GalleryImage {
  id            String       @id @default(uuid())
  galleryId     String
  imageUrl      String
  legende       String?
  transcription String?
  traduction    String?
  ordre         Int          @default(1)

  createdAt     DateTime     @default(now())

  gallery       ImageGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@index([galleryId])
  @@map("gallery_images")
}

// ==================== TEXTES & RÉCITS ====================

model TextContent {
  id              String        @id @default(uuid())
  languageId      String?
  type            String        @default("CONTE") // CONTE, HISTOIRE, CHANSON, RECIT, DESCRIPTION, LEGENDE, PROVERBE_LONG, ou custom
  titre           String
  contenu         String        // texte complet en langue locale
  traduction      String?       // traduction française
  transcription   String?       // notation phonétique
  resume          String?       // résumé court (max 300 chars)
  audioUrl        String?       // langue locale
  audioUrlFr      String?       // français
  imageUrl        String?
  niveau          String        @default("A1")   // A1, A2, B1, B2, C1
  auteur          String?
  sourceEthnique  String?
  tags            String[]      @default([])
  dureeMin        Int?          // durée de lecture estimée en minutes
  status          ContentStatus @default(DRAFT)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  language        Language?     @relation(fields: [languageId], references: [id])

  @@index([languageId, status])
  @@index([type])
  @@map("text_contents")
}

// ==================== MARCHÉ ====================

model MarcheDialogue {
  id          String   @id @default(uuid())
  languageId  String
  vendeur     String                     // Nom du vendeur (Amara, Koffi…)
  vendeurDesc String?                    // Description (Commerçant de Bouaké)
  salutation  String                     // Phrase d'accueil initiale
  repliques   Json                       // [{vendeurDit, motJuste:{mot,sens,effet}, leurres:[], conseil}]
  audioSalutation String?                // Audio de la salutation
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  language    Language @relation(fields: [languageId], references: [id])

  @@index([languageId])
  @@map("marche_dialogues")
}

// ==================== CIVISME ====================

model CivicContent {
  id          String    @id @default(uuid())
  languageId  String?
  type        String    // 'proverbe_civique', 'symbole_etat', 'sensibilisation'
  titre       String
  contenu     String    // Le proverbe/règle/conseil en langue locale (ou en français si transversal)
  traduction  String?   // Traduction si contenu en langue locale
  explication String?   // Sens profond, contexte culturel
  audioUrl    String?   // langue locale
  audioUrlFr  String?   // français
  imageUrl    String?
  genreVoix   String?   // "M" ou "F"
  valeur      String?   // 'respect', 'solidarite', 'proprete', 'securite_routiere', 'environnement', 'patriotisme', 'etat'
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  language    Language? @relation(fields: [languageId], references: [id])

  @@map("civic_content")
}

// ==================== SENS DES MOTS ====================

model SensMot {
  id               String        @id @default(uuid())
  languageId       String?
  motSource        String        // Le mot en langue locale
  transcription    String?       // Notation phonétique
  audioUrl         String?       // Prononciation native
  sensHistoriqueFr String        // Traduction française historique (souvent erronée)
  sensVeritable    String        // Signification culturelle réelle
  contexteErreur   String?       // Explication de l'origine de la divergence
  source           String?       // Locuteur natif / institution validatrice
  status           ContentStatus @default(DRAFT)
  isActive         Boolean       @default(true)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  language         Language?     @relation(fields: [languageId], references: [id])

  @@index([languageId, status])
  @@map("sens_mots")
}

// ==================== MATHÉMATIQUES ====================

model MathContenu {
  id          String    @id @default(uuid())
  languageId  String?
  type        MathType  // COMPTAGE, ADDITION, SOUSTRACTION, MULTIPLICATION, DIVISION, PAIR_IMPAIR
  titre       String
  description String?
  niveau      String    @default("A1")   // A1, A2, B1
  contenu     Json      // exercices, questions, réponses (structure flexible)
  pointsXp    Int       @default(20)
  ordre       Int       @default(0)
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  language    Language? @relation(fields: [languageId], references: [id])

  @@index([languageId, type])
  @@map("math_contenus")
}

// ==================== MONNAIE ====================

model MonnaieContenu {
  id          String       @id @default(uuid())
  languageId  String?
  type        MonnaieType  // RECONNAISSANCE, CALCUL, RENDU_MONNAIE, CONVERSION
  titre       String
  description String?
  contenu     Json         // pièces/billets, montants, exercices visuels
  pointsXp    Int          @default(20)
  ordre       Int          @default(0)
  isActive    Boolean      @default(true)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  language    Language?    @relation(fields: [languageId], references: [id])

  @@index([languageId, type])
  @@map("monnaie_contenus")
}

// ==================== PARTENAIRES / INSTITUTIONS ====================

model Partenaire {
  id          String    @id @default(uuid())
  nom         String
  logoUrl     String?
  description String?
  siteWeb     String?
  categorie   String?   // 'ia', 'institution', 'ong', 'entreprise', 'gouvernement'
  pays        String?
  isActive    Boolean   @default(true)
  ordre       Int       @default(0)  // 0 = premier affiché

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("partenaires")
}

enum MathType {
  COMPTAGE
  ADDITION
  SOUSTRACTION
  MULTIPLICATION
  DIVISION
  PAIR_IMPAIR
}

enum MonnaieType {
  RECONNAISSANCE
  CALCUL
  RENDU_MONNAIE
  CONVERSION
}

model FinanceContribution {
  id                 String   @id @default(uuid())
  contributeurNom    String?
  contributeurEmail  String?
  montant            Int      // en FCFA
  objet              String   // 'SOUTIEN_GENERAL', 'PARRAINAGE_LANGUE', etc.
  methode            String   // 'ORANGE_MONEY', 'MTN_MONEY', 'WAVE', etc.
  message            String?
  statut             String   @default("EN_ATTENTE") // 'EN_ATTENTE', 'CONFIRME', 'REJETE'
  userId             String?
  user               User?    @relation(fields: [userId], references: [id])

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("finance_contributions")
}

model Depense {
  id                String    @id @default(uuid())
  sujet             String                          // Titre court de la dépense
  objet             String                          // Catégorie : SALAIRE, INFRASTRUCTURE, MATERIEL, MARKETING, TRANSPORT, ABONNEMENT, AUTRE
  description       String?                         // Détail optionnel
  montant           Int                             // en FCFA
  date              DateTime                        // Date de la dépense
  statut            String    @default("EN_ATTENTE") // EN_ATTENTE | VALIDEE | REJETEE
  pieceJointeUrl    String?                         // URL Cloudinary du fichier
  pieceJointeNom    String?                         // Nom original du fichier
  pieceJointeType   String?                         // 'pdf', 'image', etc.
  reference         String?                         // Référence / N° de facture
  fournisseur       String?                         // Nom du fournisseur / prestataire
  createdById       String?
  createdBy         User?     @relation("depensesCreees", fields: [createdById], references: [id])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("depenses")
}

// ==================== RÉPÉTO — COMPAGNON VOCAL ILA ====================
// Phase 1 : Mode Écho — collecte de corpus audio pour les langues ethniques ivoiriennes
// Phase 2 (future) : IA de reconnaissance vocale entraînée sur corpus ILA après
// constitution d'un corpus suffisamment large grâce à nos locuteurs natifs et apprenants.

// Mot configuré dans le jeu RÉPÉTO pour une langue donnée
model RepetitorMot {
  id          String   @id @default(uuid())
  languageId  String
  languageNom String?  // Cache du nom de la langue
  mot         String   // Le mot à répéter (en langue locale)
  traduction  String?  // Traduction française
  audioUrl    String   // URL de l'audio natif certifié ILA (Cloudinary)
  genreVoix   String?  // "M" (voix masculine) | "F" (voix féminine)
  emoji       String?  // Emoji illustratif (🌳, 🐘, 🌊...)
  imageUrl    String?  // Image illustrative (Cloudinary) — prioritaire sur l'emoji en Phase Visuel-Vocal
  categorie   String   @default("general") // general, animaux, nature, famille, couleurs, chiffres
  niveau      String   @default("debutant") // debutant, intermediaire, avance
  ordre       Int      @default(0)
  actif       Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    RepetitorSession[]

  @@index([languageId, actif])
  @@map("repetitor_mots")
}

// Session enregistrée par un apprenant (enfant ou adulte) depuis l'application mobile
model RepetitorSession {
  id              String   @id @default(uuid())
  repetitorMotId  String?  // Référence au mot joué (peut être null si mot supprimé)
  languageId      String?
  languageNom     String?  // Cache
  motCible        String   // Le mot que l'apprenant devait répéter
  traduction      String?
  audioNatifUrl   String?  // URL de l'audio natif qui a été joué
  audioEnfantUrl  String   // URL de l'enregistrement de l'apprenant (Cloudinary)
  dureeMs         Int?     // Durée de l'enregistrement en millisecondes
  ageGroupe       String   @default("INCONNU") // INCONNU, MOINS5, 5_8, 9_12, 13_18, ADULTE
  statut          String   @default("BRUT")    // BRUT, SOUMIS_ILA, ARCHIVE
  scoreProximite  Float?   // Phase 2 — score de proximité vocale calculé par l'IA
  deviceId        String?  // Identifiant anonymisé de l'appareil

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  repetitorMot    RepetitorMot? @relation(fields: [repetitorMotId], references: [id], onDelete: SetNull)

  @@index([languageId])
  @@index([statut])
  @@index([createdAt])
  @@map("repetitor_sessions")
}

// ==================== CURSUS SCOLAIRE (Phase A) ====================
// Système de progression calqué sur le système éducatif ivoirien :
// CP1 → CM2 (passage automatique par score), examens charnières validés
// par le comité d'experts (Phase B), classes du secondaire, puis Parcours
// Chercheur (3 niveaux). Le test de positionnement est plafonné à la 6ème.
// Principe : « L'école est un cursus, la culture est un droit » — seuls les
// modules pédagogiques sont verrouillés ; outils et patrimoine restent libres.

enum PassageMode {
  AUTO     // Passage automatique par algorithme de score (seuil + modules obligatoires)
  COMITE   // Validation par le comité d'experts (examens charnières — Phase B)
}

enum ExamStatus {
  PENDING    // Soumis par l'élève, en attente de review
  IN_REVIEW  // Pris en charge par un expert
  APPROVED   // Passage validé par le comité
  REJECTED   // Refusé — l'élève peut retenter
}

// Les trois piliers de matières (Socle Commun, validable institutionnellement)
enum PilierMatiere {
  LANGUE_COMMUNICATION  // Alphabet, Phrases, Conjugaison, Écriture, Prononciation, Sens des Mots
  CULTURE_CITOYENNETE   // Proverbes, Contes, Musée, Civisme, Monnaie, Arbres
  PRATIQUE_METIERS      // Marché, Mathématiques, vocabulaire métiers (CNMCI — Phase D)
}

// Une classe du cursus (CP1, CP2 … Terminale, Chercheur I-III)
model GradeLevel {
  id            String      @id @default(uuid())
  code          String      @unique  // "CP1", "CE1", "6EME", "TLE", "CHERCHEUR_1"…
  nom           String               // "CP1", "Classe de 6ème", "Niveau Chercheur I"…
  ordre         Int         @unique  // 1..16 — ordonne la progression
  cycle         String               // "PRIMAIRE", "COLLEGE", "LYCEE", "CHERCHEUR"
  passageMode   PassageMode @default(AUTO)
  seuilPassage  Int         @default(75)  // % de moyenne requis pour le passage auto
  description   String?
  isActive      Boolean     @default(true)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lessons              Lesson[]
  enrollments          Enrollment[]
  historiques          EnrollmentHistory[]
  placementResults     PlacementResult[]
  examSubmissions      ExamSubmission[]
  bulletins            Bulletin[]
  fichesPedagogiques   FichePedagogique[]

  @@map("grade_levels")
}

// Inscription d'un utilisateur dans le cursus d'une langue.
// Chaque langue a son cursus indépendant (un élève peut être en CM1 en Yacouba
// et en CP1 en Baoulé). La 2ème langue se débloque à la fin du CP2 de la 1ère.
model Enrollment {
  id            String     @id @default(uuid())
  userId        String
  languageId    String
  gradeLevelId  String     // Classe actuelle
  isPrincipal   Boolean    @default(false)  // Langue principale du cursus
  moyenne       Float?     // Moyenne courante dans la classe (0-100)
  startedAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  language    Language    @relation(fields: [languageId], references: [id])
  gradeLevel  GradeLevel  @relation(fields: [gradeLevelId], references: [id])
  historique      EnrollmentHistory[]
  examSubmissions ExamSubmission[]
  notes           NoteLecon[]
  bulletins       Bulletin[]

  @@unique([userId, languageId])  // Un seul cursus par langue et par élève
  @@index([gradeLevelId])
  @@map("enrollments")
}

// Livret de scolarité — trace de chaque passage de classe
model EnrollmentHistory {
  id             String      @id @default(uuid())
  enrollmentId   String
  gradeLevelId   String      // Classe validée
  moyenneFinale  Float?
  passageMode    PassageMode // Comment le passage a été obtenu
  decidedBy      String?     // expertId si validation COMITE (Phase B)
  validatedAt    DateTime    @default(now())

  enrollment  Enrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  gradeLevel  GradeLevel  @relation(fields: [gradeLevelId], references: [id])

  @@index([enrollmentId])
  @@map("enrollment_history")
}

// Question du test de positionnement (15 min, plafonné à la 6ème)
model PlacementQuestion {
  id           String   @id @default(uuid())
  languageId   String
  niveauOrdre  Int      // Ordre du GradeLevel ciblé (difficulté croissante)
  donnees      Json     // { question, choix[], audioUrl?, imageUrl? }
  solution     Json     // Réponse(s) correcte(s)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  language  Language @relation(fields: [languageId], references: [id])

  @@index([languageId, isActive])
  @@map("placement_questions")
}

// Résultat du test de positionnement d'un élève
model PlacementResult {
  id            String   @id @default(uuid())
  userId        String
  languageId    String
  score         Float    // 0-100
  gradeLevelId  String   // Classe attribuée (plafonnée à la 6ème)
  detail        Json?    // Réponses détaillées (audit/statistiques)
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  language    Language    @relation(fields: [languageId], references: [id])
  gradeLevel  GradeLevel  @relation(fields: [gradeLevelId], references: [id])

  @@index([userId, languageId])
  @@map("placement_results")
}

// Demande de passage COMITE soumise par un élève (Phase B)
model ExamSubmission {
  id            String     @id @default(uuid())
  userId        String
  languageId    String
  enrollmentId  String
  gradeLevelId  String     // Classe dont l'élève demande le passage

  textContent   String?    // Rédaction libre
  audioUrl      String?    // Enregistrement oral (URL Cloudinary)

  status        ExamStatus @default(PENDING)
  reviewedBy    String?    // userId du membre du comité ayant statué
  commentaire   String?    // Note du comité pour l'élève
  reviewedAt    DateTime?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User       @relation("examSubmissions", fields: [userId], references: [id])
  language      Language   @relation(fields: [languageId], references: [id])
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id])
  gradeLevel    GradeLevel @relation(fields: [gradeLevelId], references: [id])
  reviewer      User?      @relation("examReviews", fields: [reviewedBy], references: [id])

  @@index([status])
  @@index([userId, languageId])
  @@map("exam_submissions")
}

// ==================== CAHIER DE NOTES & BULLETINS (Phase C) ====================

enum Trimestre {
  T1  // Septembre – Décembre
  T2  // Janvier – Mars
  T3  // Avril – Juin
}

enum MentionBulletin {
  EXCELLENT    // ≥16/20
  TRES_BIEN    // ≥14/20
  BIEN         // ≥12/20
  ASSEZ_BIEN   // ≥10/20
  PASSABLE     // ≥8/20
  INSUFFISANT  // <8/20
}

// Note individuelle d'une leçon dans le cadre du cursus
model NoteLecon {
  id           String    @id @default(uuid())
  enrollmentId String
  lessonId     String
  score        Float     // 0-100 (score brut UserProgress)
  note         Float     // 0-20 (score / 5)
  trimestre    Trimestre
  annee        Int       // Année scolaire (ex: 2026)
  tentative    Int       @default(1)
  completedAt  DateTime  @default(now())

  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id])

  @@unique([enrollmentId, lessonId])   // Meilleure tentative conservée
  @@index([enrollmentId, trimestre])
  @@map("notes_lecons")
}

// Bulletin trimestriel par élève et par langue
model Bulletin {
  id               String           @id @default(uuid())
  enrollmentId     String
  gradeLevelId     String
  trimestre        Trimestre
  annee            Int

  // Moyennes par pilier /20
  moyenneLangue    Float?           // LANGUE_COMMUNICATION
  moyenneCulture   Float?           // CULTURE_CITOYENNETE
  moyennePratique  Float?           // PRATIQUE_METIERS
  moyenneGenerale  Float?           // Moyenne globale /20
  mention          MentionBulletin?
  rang             Int?             // Position dans la classe ce trimestre
  nombreEleves     Int?             // Effectif de la classe ce trimestre
  observations     String?          // Commentaire de l'expert/admin

  // Validation + PDF
  validatedBy      String?
  validatedAt      DateTime?
  pdfUrl           String?
  codeVerification String?          @unique  // ex: BUL-2026-T1-A3B4C5

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  enrollment       Enrollment       @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  gradeLevel       GradeLevel       @relation(fields: [gradeLevelId], references: [id])
  validator        User?            @relation("bulletinValidations", fields: [validatedBy], references: [id])

  @@unique([enrollmentId, trimestre, annee])
  @@index([enrollmentId])
  @@map("bulletins")
}

// Modules pédagogiques de l'app (écrans) rattachés au cursus.
// isCursus=false → outil libre jamais verrouillé (Dictionnaire, Traducteur, SOS…)
model CurriculumModule {
  id             String        @id @default(uuid())
  moduleKey      String        @unique  // "alphabet", "conjugaison", "quiz"…
  nom            String                 // Nom affiché ("Alphabet", "Conjugaison"…)
  pilier         PilierMatiere
  minGradeOrdre  Int           @default(1)   // Ordre de classe minimal pour déblocage
  isCursus       Boolean       @default(true)
  isActive       Boolean       @default(true)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("curriculum_modules")
}

// ==================== FICHES PÉDAGOGIQUES ====================

enum TypeFiche {
  COURS
  EXERCICE
  EVALUATION
  RESSOURCE
}

model FichePedagogique {
  id          String     @id @default(cuid())
  titre       String
  description String?
  contenu     String     @db.Text
  type        TypeFiche  @default(COURS)
  pilier      PilierMatiere?
  trimestre   Trimestre?
  semaine     Int?
  isPublished Boolean    @default(false)
  fileUrl     String?

  languageId   String
  gradeLevelId String
  createdById  String

  language   Language   @relation(fields: [languageId],   references: [id])
  gradeLevel GradeLevel @relation(fields: [gradeLevelId], references: [id])
  createdBy  User       @relation("FicheCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([languageId, gradeLevelId])
  @@map("fiches_pedagogiques")
}

