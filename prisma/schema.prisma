generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ÉNUMÉRATIONS ====================

enum Role {
  USER
  CONTRIBUTOR
  EDITOR
  ADMIN
}

enum ContentStatus {
  DRAFT
  PENDING
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum ContributionType {
  WORD
  PHRASE
  IMAGE
}

enum ExerciseType {
  LISTENING
  VOCABULARY
  GRAMMAR
  GAME
  TRANSLATION
  IMAGE_WORD
}

enum LessonStepType {
  VOCABULARY
  DIALOGUE
  GRAMMAR
  EXERCISE
}

enum CulturalItemType {
  PROVERB
  TRADITION
  ANECDOTE
  TALE
  MUSIC
  DANCE
}

enum NotificationType {
  DAILY_REMINDER
  BADGE_EARNED
  CHALLENGE
  CULTURAL_POINT
  STREAK_WARNING
}

// ==================== UTILISATEURS ====================

model User {
  id                  String    @id @default(uuid())
  nom                 String
  prenom              String
  email               String    @unique
  identifiant         String?   @unique
  motDePasseHash      String?
  dateNaissance       DateTime?
  telephone           String?
  photo               String?
  role                Role      @default(USER)
  isPremium           Boolean   @default(false)
  premiumUntil        DateTime?
  pointsContribution  Int       @default(0)
  streak              Int       @default(0)
  lastActiveAt        DateTime?
  isActive            Boolean   @default(true)

  // OAuth
  googleId            String?   @unique
  facebookId          String?   @unique

  // Préférences
  niveauPref          String?
  languesFavorites    String[]
  notifEnabled        Boolean   @default(true)
  tuteurPref          String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  progress            UserProgress[]
  contributions       Contribution[]
  imageContributions  ImageContribution[]
  badges              UserBadge[]
  pronunciationReqs   PronunciationRequest[]
  notifications       Notification[]
  organizationMember  OrganizationMember[]
  audioContributions  AudioContribution[]
  practiceSessions    PracticeSession[]

  @@map("users")
}

// ==================== LANGUES ====================

model Language {
  id              String    @id @default(uuid())
  nom             String    @unique
  code            String    @unique  // ex: "baoule", "dioula"
  famille         String?   // Akan, Mandé, Krou, etc.
  region          String?
  locuteurs       Int?
  imageDrapeau    String?
  description     String?
  ordreAffichage  Int       @default(0)
  isActive        Boolean   @default(true)
  isInMvp         Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  lessons         Lesson[]
  dictEntries     DictionaryEntry[]
  usefulPhrases   UsefulPhrase[]
  contributions   Contribution[]
  culturalItems   CulturalItem[]
  tutors          Tutor[]
  videos          Video[]
  audioContribs   AudioContribution[]
  practiceSessions PracticeSession[]

  @@map("languages")
}

// ==================== LEÇONS ====================

model Lesson {
  id          String    @id @default(uuid())
  languageId  String
  titre       String
  description String?
  ordre       Int       @default(0)
  pointsXp    Int       @default(50)
  niveau      String    @default("A1") // A1, A2, B1, B2, C1
  imageUrl    String?
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  language    Language  @relation(fields: [languageId], references: [id])
  steps       LessonStep[]
  progress    UserProgress[]

  @@map("lessons")
}

model LessonStep {
  id        String         @id @default(uuid())
  lessonId  String
  type      LessonStepType
  contenu   Json           // contenu dynamique selon le type
  ordre     Int            @default(0)
  audioUrl  String?
  imageUrl  String?

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@map("lesson_steps")
}

model Exercise {
  id          String       @id @default(uuid())
  stepId      String
  type        ExerciseType
  donnees     Json         // questions, choix, etc.
  solution    Json         // réponses correctes
  pointsXp    Int          @default(10)
  explication String?

  step        LessonStep   @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("exercises")
}

// ==================== DICTIONNAIRE ====================

model DictionaryEntry {
  id              String        @id @default(uuid())
  languageId      String
  mot             String
  transcription   String?       // notation phonétique
  traduction      String        // traduction en français
  audioUrl        String?
  imageUrl        String?
  exemplePhrase   String?
  exempleTraduction String?
  categorie       String?       // corps, nature, famille, etc.
  statutSRS       Int           @default(0)  // niveau mémorisation 0-5
  status          ContentStatus @default(DRAFT)
  contributorId   String?
  moderatorId     String?
  moderatedAt     DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  language        Language      @relation(fields: [languageId], references: [id])
  pronunciationReqs PronunciationRequest[]

  @@index([languageId, status])
  @@map("dictionary_entries")
}

model UsefulPhrase {
  id            String        @id @default(uuid())
  languageId    String
  phrase        String
  transcription String?
  traduction    String
  audioUrl      String?
  categorie     String?       // salutations, commerce, urgence, etc.
  contexte      String?
  status        ContentStatus @default(DRAFT)
  contributorId String?
  moderatorId   String?
  moderatedAt   DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  language      Language      @relation(fields: [languageId], references: [id])

  @@index([languageId, status])
  @@map("useful_phrases")
}

// ==================== CONTRIBUTIONS ====================

model Contribution {
  id            String           @id @default(uuid())
  userId        String
  type          ContributionType
  languageId    String
  contenu       Json             // mot/phrase + traduction + contexte
  audioUrl      String?
  imageUrl      String?
  status        ContentStatus    @default(PENDING)
  moderatorId   String?
  moderatedAt   DateTime?
  commentaire   String?          // retour du modérateur

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id])
  language      Language         @relation(fields: [languageId], references: [id])

  @@index([status, type])
  @@map("contributions")
}

model ImageContribution {
  id            String        @id @default(uuid())
  userId        String
  languageId    String
  imageUrl      String
  legende       String?
  motAssocie    String?
  categorie     String?
  source        String?
  status        ContentStatus @default(PENDING)
  moderatorId   String?
  moderatedAt   DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])

  @@map("image_contributions")
}

// ==================== CONTENU CULTUREL ====================

model CulturalItem {
  id              String           @id @default(uuid())
  languageId      String?
  type            CulturalItemType
  titre           String?
  contenu         String
  traduction      String?
  audioUrl        String?
  imageUrl        String?
  videoUrl        String?
  auteur          String?
  sourceEthnique  String?
  datePublication DateTime         @default(now())
  isActive        Boolean          @default(true)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  language        Language?        @relation(fields: [languageId], references: [id])

  @@map("cultural_items")
}

// ==================== TUTEURS IA ====================

model Tutor {
  id                  String   @id @default(uuid())
  languageId          String
  nomAvatar           String
  genre               String   @default("M") // M ou F
  imageUrl            String?
  videoUrl            String?
  voixConfig          Json     // config TTS, vitesse, pitch, etc.
  personalite         String?
  messagesPersonnalises Json?
  isActive            Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  language            Language @relation(fields: [languageId], references: [id])

  @@map("tutors")
}

model PronunciationRequest {
  id              String   @id @default(uuid())
  userId          String
  dictEntryId     String
  audioRecording  String   // URL du fichier audio
  feedbackAvatar  Json?    // scores par dimension
  scoreTones      Float?
  scoreConsonants Float?
  scoreVowels     Float?
  scoreRythm      Float?
  scoreGlobal     Float?

  createdAt       DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id])
  dictEntry       DictionaryEntry @relation(fields: [dictEntryId], references: [id])

  @@map("pronunciation_requests")
}

// ==================== PROGRESSION ====================

model UserProgress {
  id             String   @id @default(uuid())
  userId         String
  lessonId       String
  statut         String   @default("not_started") // not_started, in_progress, completed
  score          Int?
  dateCompletion DateTime?
  attempts       Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  lesson         Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("user_progress")
}

// ==================== GAMIFICATION ====================

model Badge {
  id          String   @id @default(uuid())
  nom         String   @unique
  description String
  imageUrl    String?
  categorie   String   // linguistique, culturel, social
  condition   Json     // règle d'obtention
  pointsXp    Int      @default(0)

  users       UserBadge[]

  @@map("badges")
}

model UserBadge {
  id          String   @id @default(uuid())
  userId      String
  badgeId     String
  obtainedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  badge       Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ==================== ORGANISATIONS ====================

model Organization {
  id        String   @id @default(uuid())
  nom       String
  email     String   @unique
  contact   String?
  statut    String   @default("active")
  apiKey    String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   OrganizationMember[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  userId         String
  organizationId String

  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// ==================== VIDÉOS ====================

model Video {
  id            String        @id @default(uuid())
  languageId    String?
  titre         String
  description   String?
  url           String        // URL YouTube ou Cloudinary
  thumbnailUrl  String?
  duree         Int?          // durée en secondes
  categorie     String        @default("culturel") // prononciation, culturel, tutoriel, musique, documentaire
  source        String        @default("youtube") // youtube, cloudinary, externe
  ordre         Int           @default(0)
  isActive      Boolean       @default(true)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  language      Language?     @relation(fields: [languageId], references: [id])

  @@index([languageId, categorie])
  @@map("videos")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  titre     String
  corps     String
  isRead    Boolean          @default(false)
  data      Json?

  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ==================== CONTRIBUTIONS AUDIO (IA LINGUISTIQUE) ====================

model AudioContribution {
  id            String    @id @default(uuid())
  userId        String
  languageId    String
  mot           String                      // mot ou phrase en langue locale
  traduction    String?                     // traduction française
  audioUrl      String                      // URL de l'enregistrement audio
  transcription String?                     // notation phonétique
  categorie     String?                     // salutations, famille, marché...
  duree         Int?                        // durée en millisecondes
  isValidated   Boolean   @default(false)   // validé par un éditeur
  validatedBy   String?
  validatedAt   DateTime?
  qualityScore  Float?                      // score qualité 0-5
  timesPlayed   Int       @default(0)       // nombre de fois joué par l'IA
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])
  language      Language  @relation(fields: [languageId], references: [id])

  @@index([languageId, isValidated])
  @@index([mot, languageId])
  @@map("audio_contributions")
}

// ==================== SESSIONS DE PRATIQUE ====================

model PracticeSession {
  id            String    @id @default(uuid())
  userId        String
  languageId    String
  tutorId       String?
  mode          String    @default("listen_repeat") // listen_repeat, free_speak, quiz
  wordsCount    Int       @default(0)               // nombre de mots pratiqués
  correctCount  Int       @default(0)               // nombre de bonnes réponses
  duration      Int?                                // durée en secondes
  audioRecordings Json?                             // tableau d'URLs des enregistrements

  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id])
  language      Language  @relation(fields: [languageId], references: [id])

  @@map("practice_sessions")
}
