# LLM
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
LLM_PROVIDER="anthropic"  # "openai" ou "anthropic"

# Redis
REDIS_URL="redis://localhost:6379"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Serveur
PORT=8000
ENV=development

# Modèles IA
ASR_MODEL="facebook/mms-1b-all"
TTS_MODEL="facebook/mms-tts"
BLIP_MODEL="Salesforce/blip2-opt-2.7b"
USE_GPU=false
